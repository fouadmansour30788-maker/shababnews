# Copy to .env.local for local dev, and set the same in Vercel → Project → Settings → Environment Variables.

# Gemini API key for the AI chatbot (Farah). Get one at https://aistudio.google.com/apikey
# Server-side key (preferred — kept secret, used by /api/chat):
GEMINI_API_KEY=

# Optional public fallback (exposed to the browser — only if you call Gemini client-side):
NEXT_PUBLIC_GEMINI_API_KEY=
